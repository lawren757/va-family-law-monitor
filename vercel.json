{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "crons": [
    {
      "path": "/api/cron/weekly-update",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/vlw-digest",
      "schedule": "0 22 * * 1"
    }
  ],

  "functions": {
    "app/api/cron/weekly-update/route.ts": {
      "maxDuration": 300
    },
    "app/api/research/route.ts": {
      "maxDuration": 60
    }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
