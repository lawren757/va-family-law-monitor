# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
CRON_SECRET=          # openssl rand -hex 32

# ── Vercel Postgres (auto-set by Vercel when you add a Postgres store) ──────
POSTGRES_URL=         # Set by Vercel Postgres integration
# If not set, the app falls back to reading data/updates.json

# ── Gemini AI (Google AI Studio) ────────────────────────────────────────────
GEMINI_API_KEY=       # https://aistudio.google.com/app/apikey

# ── Google Sheets (backup export) ───────────────────────────────────────────
GOOGLE_SHEETS_ID=     # Spreadsheet ID from the URL
GOOGLE_SHEETS_TAB=Sheet1
GOOGLE_SERVICE_ACCOUNT_JSON=  # Paste entire JSON key content

# ── GitHub Actions (VLW digest scraper) ─────────────────────────────────────
GITHUB_PAT=           # Token with repo + workflow scopes
GITHUB_OWNER=         # GitHub username or org
GITHUB_REPO=          # Repository name

# ── Optional: Notifications ─────────────────────────────────────────────────
# RESEND_API_KEY=     # For email notifications via Resend
# NOTIFY_EMAIL=       # Email address for update notifications
# SLACK_WEBHOOK_URL=  # Slack webhook for notifications
